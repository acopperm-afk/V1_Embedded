 149:Core/Src/main.c ****   HAL_RCCEx_PeriphCLKConfig(&PeriphClkInit);
 150:Core/Src/main.c ****   __HAL_RCC_LPUART1_CLK_ENABLE();
 151:Core/Src/main.c ****   GPIO_InitStruct.Pin       = GPIO_PIN_2 | GPIO_PIN_3;
 152:Core/Src/main.c ****   GPIO_InitStruct.Mode      = GPIO_MODE_AF_PP;
 153:Core/Src/main.c ****   GPIO_InitStruct.Pull      = GPIO_NOPULL;
 154:Core/Src/main.c ****   GPIO_InitStruct.Speed     = GPIO_SPEED_FREQ_LOW;
 155:Core/Src/main.c ****   GPIO_InitStruct.Alternate = GPIO_AF12_LPUART1;
 156:Core/Src/main.c ****   HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);
 157:Core/Src/main.c **** 
 158:Core/Src/main.c ****   huart2.Instance          = LPUART1;
 159:Core/Src/main.c ****   huart2.Init.BaudRate     = 9600;
 160:Core/Src/main.c ****   huart2.Init.WordLength   = UART_WORDLENGTH_8B;
 161:Core/Src/main.c ****   huart2.Init.StopBits     = UART_STOPBITS_1;
 162:Core/Src/main.c ****   huart2.Init.Parity       = UART_PARITY_NONE;
 163:Core/Src/main.c ****   huart2.Init.Mode         = UART_MODE_TX_RX;
 164:Core/Src/main.c ****   huart2.Init.HwFlowCtl    = UART_HWCONTROL_NONE;
 165:Core/Src/main.c ****   HAL_UART_Init(&huart2);
 166:Core/Src/main.c ****   /* USER CODE BEGIN 2 */
 167:Core/Src/main.c **** 
 168:Core/Src/main.c ****   /* USER CODE END 2 */
 169:Core/Src/main.c **** 
 170:Core/Src/main.c ****   /* Infinite loop */
 171:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 172:Core/Src/main.c **** 
 173:Core/Src/main.c ****   while (1)
 174:Core/Src/main.c ****   {
 175:Core/Src/main.c ****     /* USER CODE END WHILE */
 176:Core/Src/main.c ****      // Read ADC
 177:Core/Src/main.c ****     HAL_ADC_Start(&hadc1);
 178:Core/Src/main.c ****     HAL_ADC_PollForConversion(&hadc1, 10);
 179:Core/Src/main.c ****     uint32_t raw = HAL_ADC_GetValue(&hadc1);
 180:Core/Src/main.c ****     // Compute voltage in integer mV to avoid float printf issues: 3300mV / 4095
 181:Core/Src/main.c ****     uint32_t voltage_mv = (raw * 3300UL) / 4095UL;
 182:Core/Src/main.c **** 
 183:Core/Src/main.c ****     // Read digital pin
 184:Core/Src/main.c ****     GPIO_PinState digital = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_10);
 185:Core/Src/main.c **** 
 186:Core/Src/main.c ****     if (digital == GPIO_PIN_RESET)   // active-low: sensor pulls DO low on detection
 187:Core/Src/main.c ****     {
 188:Core/Src/main.c ****       HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
 189:Core/Src/main.c ****       HAL_Delay(500);   // debounce: ignore further triggers for 500 ms
 190:Core/Src/main.c ****     }
 191:Core/Src/main.c **** 
 192:Core/Src/main.c ****     // Format and send over UART (voltage in mV, no float needed)
 193:Core/Src/main.c ****     char buf[80];
 194:Core/Src/main.c ****     int len = snprintf(buf, sizeof(buf),
 195:Core/Src/main.c ****         "Analog: %lu.%03luV, Sound: %s\r\n",
 196:Core/Src/main.c ****         voltage_mv / 1000UL,
 197:Core/Src/main.c ****         voltage_mv % 1000UL,
 198:Core/Src/main.c ****         (digital == GPIO_PIN_RESET) ? "DETECTED" : "quiet");
 199:Core/Src/main.c ****     HAL_UART_Transmit(&huart2, (uint8_t*)buf, len, 100);
 200:Core/Src/main.c **** 
 201:Core/Src/main.c ****     HAL_Delay(200);
