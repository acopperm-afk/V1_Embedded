 109:Core/Src/main.c ****   // --- GPIO: PA10 as digital input (D2 on Arduino header, sound sensor DO) ---
 110:Core/Src/main.c ****   // Most LM393-based sound sensors pull DO LOW on detection (active-low).
 111:Core/Src/main.c ****   // Use pull-up so the pin reads HIGH at rest and LOW when sound is detected.
