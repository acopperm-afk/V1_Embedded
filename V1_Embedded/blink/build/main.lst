 143:Core/Src/main.c ****   // --- LPUART1: PA2(TX)/PA3(RX) → Virtual COM port at 9600 ---
 144:Core/Src/main.c ****   // LPUART1 requires an explicit peripheral clock source on STM32G4.
ARM GAS  C:\Users\alexc\AppData\Local\Temp\cc2GdvmS.s 			page 4


 145:Core/Src/main.c ****   // Route it to HSI (16 MHz) so baud rate calculation is correct.
 146:Core/Src/main.c ****   RCC_PeriphCLKInitTypeDef PeriphClkInit = {0};
 147:Core/Src/main.c ****   PeriphClkInit.PeriphClockSelection = RCC_PERIPHCLK_LPUART1;
