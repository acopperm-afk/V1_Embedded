 105:Core/Src/main.c **** 
 106:Core/Src/main.c ****   // --- GPIO: PA10 as digital input (D2 on Arduino header, sound sensor DO) ---
 107:Core/Src/main.c ****   // Most LM393-based sound sensors pull DO LOW on detection (active-low).
 108:Core/Src/main.c ****   // Use pull-up so the pin reads HIGH at rest and LOW when sound is detected.
 109:Core/Src/main.c ****   GPIO_InitStruct.Pin   = GPIO_PIN_10;
 110:Core/Src/main.c ****   GPIO_InitStruct.Mode  = GPIO_MODE_INPUT;
 111:Core/Src/main.c ****   GPIO_InitStruct.Pull  = GPIO_PULLUP;
 112:Core/Src/main.c ****   GPIO_InitStruct.Speed = 0;  // not used for inputs
 113:Core/Src/main.c ****   HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);
 114:Core/Src/main.c **** 
