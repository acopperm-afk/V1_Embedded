 204:Core/Src/main.c **** 
 205:Core/Src/main.c ****   // --- Startup banner ---
 206:Core/Src/main.c ****   const char *banner =
 207:Core/Src/main.c ****       "\r\n=== Blink Firmware Ready ===\r\n"
 208:Core/Src/main.c ****       "Servo : TIM3 CH2 -> PC7 (D9)\r\n"
 209:Core/Src/main.c ****       "Sound : PA10 (D2) digital, PA0 (A0) analog\r\n"
 210:Core/Src/main.c ****       "UART  : 9600 8N1\r\n"
 211:Core/Src/main.c ****       "============================\r\n\r\n";
 212:Core/Src/main.c ****   HAL_UART_Transmit(&huart2, (uint8_t*)banner, strlen(banner), 500);
 213:Core/Src/main.c **** 
 214:Core/Src/main.c ****   /* Infinite loop */
 215:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 216:Core/Src/main.c **** 
 217:Core/Src/main.c ****   // --- Servo state ---
 218:Core/Src/main.c ****   // Position in µs CCR: 1000 = -90°, 1500 = 0°, 2000 = +90°
 219:Core/Src/main.c ****   // 45° = 500/4 = 125 µs step
 220:Core/Src/main.c ****   // Direction: +1 = clockwise (+45° per trigger), -1 = anticlockwise
 221:Core/Src/main.c ****   int32_t  servo_pos_us  = 1500;   // start at centre (0°)
 222:Core/Src/main.c ****   int8_t   servo_dir     = 1;      // currently moving clockwise
 223:Core/Src/main.c ****   uint32_t last_move_ms  = 0;      // timestamp of last servo move
 224:Core/Src/main.c **** 
 225:Core/Src/main.c ****   while (1)
 226:Core/Src/main.c ****   {
 227:Core/Src/main.c ****     /* USER CODE END WHILE */
 228:Core/Src/main.c ****      // Read ADC
 229:Core/Src/main.c ****     HAL_ADC_Start(&hadc1);
 230:Core/Src/main.c ****     HAL_ADC_PollForConversion(&hadc1, 10);
 231:Core/Src/main.c ****     uint32_t raw = HAL_ADC_GetValue(&hadc1);
 232:Core/Src/main.c ****     // Compute voltage in integer mV to avoid float printf issues: 3300mV / 4095
 233:Core/Src/main.c ****     uint32_t voltage_mv = (raw * 3300UL) / 4095UL;
 234:Core/Src/main.c **** 
 235:Core/Src/main.c ****     // Read digital pin
 236:Core/Src/main.c ****     GPIO_PinState digital = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_10);
 237:Core/Src/main.c **** 
 238:Core/Src/main.c ****     if (digital == GPIO_PIN_RESET)   // active-low: sensor pulls DO low on detection
 239:Core/Src/main.c ****     {
 240:Core/Src/main.c ****       HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
 241:Core/Src/main.c **** 
 242:Core/Src/main.c ****       // Move servo 45° in current direction, max 1 move per second
 243:Core/Src/main.c ****       uint32_t now = HAL_GetTick();
 244:Core/Src/main.c ****       if ((now - last_move_ms) >= 1000)
 245:Core/Src/main.c ****       {
 246:Core/Src/main.c ****         last_move_ms  = now;
 247:Core/Src/main.c ****         servo_pos_us += servo_dir * 125;   // 45° = 125 µs
 248:Core/Src/main.c **** 
 249:Core/Src/main.c ****         // Clamp and reverse direction at limits (-90° = 1000 µs, +90° = 2000 µs)
 250:Core/Src/main.c ****         if (servo_pos_us >= 2000)
 251:Core/Src/main.c ****         {
 252:Core/Src/main.c ****           servo_pos_us = 2000;
 253:Core/Src/main.c ****           servo_dir    = -1;   // hit +90°, reverse to anticlockwise
 254:Core/Src/main.c ****         }
 255:Core/Src/main.c ****         else if (servo_pos_us <= 1000)
 256:Core/Src/main.c ****         {
 257:Core/Src/main.c ****           servo_pos_us = 1000;
 258:Core/Src/main.c ****           servo_dir    = 1;    // hit -90°, reverse to clockwise
ARM GAS  C:\Users\alexc\AppData\Local\Temp\ccyDAKxo.s 			page 6


 259:Core/Src/main.c ****         }
 260:Core/Src/main.c **** 
 261:Core/Src/main.c ****         __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_2, (uint32_t)servo_pos_us);
 262:Core/Src/main.c ****       }
 263:Core/Src/main.c **** 
 264:Core/Src/main.c ****       HAL_Delay(500);   // debounce: ignore further triggers for 500 ms
 265:Core/Src/main.c ****     }
 266:Core/Src/main.c **** 
 267:Core/Src/main.c ****     // Format and send over UART (voltage in mV, no float needed)
 268:Core/Src/main.c ****     char buf[80];
 269:Core/Src/main.c ****     int len = snprintf(buf, sizeof(buf),
 270:Core/Src/main.c ****         "Analog: %u.%03uV, Sound: %s\r\n",
 271:Core/Src/main.c ****         (unsigned int)(voltage_mv / 1000UL),
 272:Core/Src/main.c ****         (unsigned int)(voltage_mv % 1000UL),
 273:Core/Src/main.c ****         (digital == GPIO_PIN_RESET) ? "DETECTED" : "quiet");
 274:Core/Src/main.c ****     HAL_UART_Transmit(&huart2, (uint8_t*)buf, len, 100);
 275:Core/Src/main.c **** 
 276:Core/Src/main.c ****     HAL_Delay(200);
 277:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 278:Core/Src/main.c ****   }
 279:Core/Src/main.c ****   /* USER CODE END 3 */
 280:Core/Src/main.c **** }
