 170:Core/Src/main.c ****   // --- TIM3 CH2: PC7 (D9 on CN5) as PWM output for SG90 servo ---
 171:Core/Src/main.c ****   // System clock = HSI = 16 MHz
 172:Core/Src/main.c ****   // Prescaler = 15 → timer clock = 16MHz / 16 = 1 MHz (1 µs per tick)
 173:Core/Src/main.c ****   // Period = 19999 → 20 ms frame (50 Hz), counts 0..19999
 174:Core/Src/main.c ****   // CCR range: 1000 = 1.0 ms (-90°), 1500 = 1.5 ms (0°), 2000 = 2.0 ms (+90°)
 175:Core/Src/main.c ****   __HAL_RCC_GPIOC_CLK_ENABLE();
 176:Core/Src/main.c ****   __HAL_RCC_TIM3_CLK_ENABLE();
 177:Core/Src/main.c ****   GPIO_InitStruct.Pin       = GPIO_PIN_7;
 178:Core/Src/main.c ****   GPIO_InitStruct.Mode      = GPIO_MODE_AF_PP;
 179:Core/Src/main.c ****   GPIO_InitStruct.Pull      = GPIO_NOPULL;
 180:Core/Src/main.c ****   GPIO_InitStruct.Speed     = GPIO_SPEED_FREQ_LOW;
 181:Core/Src/main.c ****   GPIO_InitStruct.Alternate = GPIO_AF2_TIM3;
 182:Core/Src/main.c ****   HAL_GPIO_Init(GPIOC, &GPIO_InitStruct);
 183:Core/Src/main.c **** 
 184:Core/Src/main.c ****   htim3.Instance               = TIM3;
 185:Core/Src/main.c ****   htim3.Init.Prescaler         = 15;          // 16 MHz / 16 = 1 MHz
 186:Core/Src/main.c ****   htim3.Init.CounterMode       = TIM_COUNTERMODE_UP;
 187:Core/Src/main.c ****   htim3.Init.Period            = 19999;        // 20 ms
 188:Core/Src/main.c ****   htim3.Init.ClockDivision     = TIM_CLOCKDIVISION_DIV1;
 189:Core/Src/main.c ****   htim3.Init.RepetitionCounter = 0;
 190:Core/Src/main.c ****   htim3.Init.AutoReloadPreload = TIM_AUTORELOAD_PRELOAD_ENABLE;
 191:Core/Src/main.c ****   HAL_TIM_PWM_Init(&htim3);
 192:Core/Src/main.c **** 
 193:Core/Src/main.c ****   TIM_OC_InitTypeDef sConfigOC = {0};
 194:Core/Src/main.c ****   sConfigOC.OCMode       = TIM_OCMODE_PWM1;
 195:Core/Src/main.c ****   sConfigOC.Pulse        = 1500;              // start at 0° (centre)
 196:Core/Src/main.c ****   sConfigOC.OCPolarity   = TIM_OCPOLARITY_HIGH;
 197:Core/Src/main.c ****   sConfigOC.OCFastMode   = TIM_OCFAST_DISABLE;
 198:Core/Src/main.c ****   HAL_TIM_PWM_ConfigChannel(&htim3, &sConfigOC, TIM_CHANNEL_2);
